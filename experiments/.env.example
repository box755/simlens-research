# 複製這個檔案成 .env，填入實際值。.env 不會被 commit。

# API keys — 研究計畫的必要 API
ANTHROPIC_API_KEY=sk-ant-...           # Claude 蒸餾（teacher）
OPENAI_API_KEY=sk-...                  # GPT-4o-mini spot-check

# HuggingFace token — 下載 Llama-3.2-3B-Instruct（gated model）
HF_TOKEN=hf_...

# YouTube Data API v3 — 收集 100 部影片素材
YOUTUBE_API_KEY=AIza...

# Optional: Weights & Biases 追蹤訓練
WANDB_API_KEY=
WANDB_PROJECT=simlens-research

# Ollama endpoint（如果不用預設 localhost:11434）
OLLAMA_HOST=http://localhost:11434
